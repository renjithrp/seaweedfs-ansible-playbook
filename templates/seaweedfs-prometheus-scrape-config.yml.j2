# Generated by site.yml from the current inventory.
scrape_configs:
  - job_name: seaweedfs-master
    metrics_path: {{ seaweedfs_prometheus_metrics_path }}
    scrape_interval: {{ seaweedfs_prometheus_scrape_interval }}
    static_configs:
{% for h in groups.get('masters', []) %}
      - targets:
          - '{{ hostvars[h]["ansible_host"] }}:{{ seaweedfs_master_metrics_port }}'
        labels:
          cluster: '{{ seaweedfs_observability_cluster }}'
          datacenter: '{{ hostvars[h].get("seaweedfs_data_center", "") }}'
          host: '{{ h }}'
          rack: '{{ hostvars[h].get("seaweedfs_rack", "") }}'
          role: master
{% endfor %}

  - job_name: seaweedfs-volume
